# === Data / project roots ===
# Root of this repository (contains ehrshot/, UKB_validation/, EHRSHOT_ASSETS/).
EHRSHOT_BENCHMARK_DIR=
# UK Biobank raw data location.
UKB_DATA_LOCATION=
# UK Biobank EID mapping file (tsv linking data-version patient ids).
UKB_EID_MAPPING=
# UK Biobank project directory (holds derived data + results).
UKB_PROJECT_DIR=
# Shared Hugging Face cache (used as HF_HOME / model cache).
HUGGINGFACE_CACHE=

# === Conda environments (used by the SLURM/bash launch scripts) ===
# Conda profile script sourced to enable `conda activate` in non-interactive shells.
CONDA_PROFILE_SCRIPT=
# Conda env (name or path) for the EHRSHOT experiments (ehrshot/bash_scripts/run_experiments.sh).
EHRSHOT_CONDA_ENV=
# Conda env (name or path) for the UK Biobank CLMBR baseline (UKB_validation/clmbr_baseline).
UKB_CONDA_ENV=
